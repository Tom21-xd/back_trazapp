# =============================================================================
# back_trazapp - Variables de entorno (PLANTILLA)
# -----------------------------------------------------------------------------
# Copia este archivo a `.env` y reemplaza los valores.
#   cp .env.example .env
# NUNCA subas tu `.env` real al repositorio (ya está en .gitignore).
# =============================================================================

# Entorno: development | production | test
NODE_ENV=development

# Puerto del backend (NO usar 3000 si el frontend corre en 3000)
PORT=3000

# -----------------------------------------------------------------------------
# Base de datos PostgreSQL
# Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/BASEDATOS?schema=public
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:CAMBIA_ESTA_CONTRASENA@localhost:5432/trazapp?schema=public"

# -----------------------------------------------------------------------------
# JWT — Genera secretos fuertes y ÚNICOS (mínimo 32 caracteres).
# Genera uno con:   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# -----------------------------------------------------------------------------
JWT_SECRET="REEMPLAZAR_POR_SECRETO_ALEATORIO_DE_AL_MENOS_32_CARACTERES"
JWT_EXPIRATION="1h"
JWT_REFRESH_SECRET="REEMPLAZAR_POR_OTRO_SECRETO_ALEATORIO_DISTINTO_32_CHARS"
JWT_REFRESH_EXPIRATION="7d"

# -----------------------------------------------------------------------------
# CORS — URL(s) del frontend autorizado (sin barra final).
# Admite varios orígenes separados por coma:
#   FRONTEND_URL="https://trazapp.florencia.gov.co,https://www.trazapp.florencia.gov.co"
# -----------------------------------------------------------------------------
FRONTEND_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# Swagger — En producción la doc está deshabilitada por defecto.
# Pon "true" sólo si necesitas exponer /api/docs en producción.
# -----------------------------------------------------------------------------
SWAGGER_ENABLED=false

# -----------------------------------------------------------------------------
# Archivos adjuntos (almacenamiento en disco local)
# -----------------------------------------------------------------------------
# Carpeta donde se guardan los archivos subidos (relativa al cwd o absoluta)
UPLOAD_DIR="uploads"
# Tamaño máximo por archivo en MB
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------------
# Rate limiting (protección contra fuerza bruta / abuso)
# -----------------------------------------------------------------------------
# Ventana en segundos y nº máximo de peticiones por ventana (global)
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# -----------------------------------------------------------------------------
# Notificaciones Web Push (VAPID). Genera el par de llaves con:
#   npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:soporte@florencia.gov.co"

# -----------------------------------------------------------------------------
# Email (SMTP) — notificaciones por correo. Para Gmail usa una
# "Contraseña de aplicación" (no la contraseña normal de la cuenta).
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu-cuenta@gmail.com"
SMTP_PASS="contrasena_de_aplicacion"
EMAIL_FROM="TrazApp <tu-cuenta@gmail.com>"
